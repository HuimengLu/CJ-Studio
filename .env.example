# OpenAI API key for the Testing 2 pipeline (backend/openai_engine.py).
# Get one at https://platform.openai.com/api-keys  — do NOT commit the real .env
# Note: gpt-image-1 requires a *verified* OpenAI organization.
OPENAI_API_KEY=your-key-here

# Optional overrides (defaults shown)
# CJ_OPENAI_MODEL=gpt-image-2
# CJ_OPENAI_SIZE=1536x1024    # 1024x1024 | 1536x1024 | 1024x1536 | auto
# CJ_OPENAI_QUALITY=low       # low | medium | high | auto
# CJ_OPENAI_MODERATION=low    # low | auto
# CJ_OPENAI_FIDELITY=high     # input_fidelity (default: API default = low)
